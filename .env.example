# Forge environment — copy to .env.local and fill in your own values.
# These are only needed for open-ended natural-language scaffolding
# (`forge scaffold "<prompt>"`). Built-in example prompts work offline.
#
# Provide ONE of the following:

# Vercel AI Gateway key — https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=

# ...or a direct OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=
