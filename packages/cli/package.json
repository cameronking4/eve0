{
  "name": "@forge/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "forge": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "studio.tar.gz"
  ],
  "scripts": {
    "build": "tsc",
    "bundle:studio": "bash ../../scripts/bundle-studio.sh",
    "prepack": "pnpm run build && pnpm run bundle:studio",
    "typecheck": "tsc --noEmit",
    "dev": "node --watch dist/index.js"
  },
  "dependencies": {
    "@forge/core": "workspace:*",
    "@forge/scaffolder": "workspace:*",
    "commander": "^12.1.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
